---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostCardSkeleton from "@/components/skeleton/PostCardSkeleton.astro";
import config from "@/config";
import { useTranslations } from "@/i18n";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.nav.friends} | ${config.site.title}`}>
  <Header pageTitle={t.nav.friends} />
  <main
    id="main-content"
    data-layout="friends"
    class="app-layout"
  >
    <section id="recent-posts" class="pb-0">
      {/* 初始加载骨架屏：friends.ts fetch 成功后会清空并替换为真实列表 */}
      <ul id="post-list" class="space-y-4">
        {Array.from({ length: config.posts.perPage }).map(() => <PostCardSkeleton />)}
      </ul>
      <div id="infinite-scroll-sentinel" />
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { initFriends } from "@/scripts/friends";
  document.addEventListener("astro:page-load", initFriends);
</script>