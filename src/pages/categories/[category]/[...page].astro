---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import { getCategories, getPostsByCategory } from "@/utils/categories";
import { useTranslations } from "@/i18n";
import config from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const categories = getCategories(posts);

  return categories.flatMap(category => {
    const categoryPosts = getPostsByCategory(posts, category.name);

    return paginate(categoryPosts, {
      params: { category: category.slug },
      props: { categoryName: category.name },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, categoryName } = Astro.props;
const { category } = Astro.params as { category?: string };

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout
  title={`${t.pages.categoryTitle}: ${categoryName} | ${config.site.title}`}
>
  <Header pageTitle={`${t.pages.categoryTitle}: ${categoryName}`} />

  <Main>
    <ul id="post-list" class="space-y-4">
      {page.data.map(data => <Card {...data} />)}
    </ul>
    <div id="infinite-scroll-sentinel" data-next-page={page.url.next} />
  </Main>

  <Footer />

  <noscript>
    <div class="mt-4 flex justify-center">
      <a
        href={page.url.next ?? page.url.prev ?? `/categories/${category}`}
        class="text-accent hover:underline"
      >
        Next Page &rarr;
      </a>
    </div>
  </noscript>
</Layout>

<script>
  import { initInfiniteScroll } from "@/scripts/infiniteScroll";
  document.addEventListener("astro:page-load", initInfiniteScroll);
</script>
