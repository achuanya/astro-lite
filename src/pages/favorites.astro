---
/**
 * 收藏页路由
 *
 * @fileoverview 渲染用户的收藏内容页面，支持懒加载
 *
 * 文件用途：
 * - 作为收藏内容的展示页面，从 Markdown 文件中读取并解析收藏数据
 * - 提供卡片式布局展示收藏项，每个收藏项包含标题、描述、链接等信息
 * - 支持懒加载机制，当收藏项数量较多时优化页面性能
 *
 * 核心逻辑：
 * 1. 在构建时读取 data/favorites.md 文件（Markdown 格式）
 * 2. 使用 parseFavorites 工具函数解析 Markdown 内容，提取收藏项数据
 * 3. 根据配置决定初始显示的收藏项数量（SITE.favoritesPerIndex）
 * 4. 超出初始数量的收藏项添加 hidden 类，由懒加载脚本控制显示
 * 5. 每个收藏项使用 FavoriteCard 组件渲染，支持自定义样式和交互
 *
 * 依赖关系：
 * - 使用 parseFavorites 工具函数解析 Markdown 格式的收藏数据
 * - 使用 FavoriteCard 组件渲染单个收藏项
 * - 依赖 /lazy-list.js 脚本实现懒加载交互
 * - 使用 SITE 配置中的 favoritesPerIndex 和 favoritesPerPage 控制显示策略
 *
 * 数据来源：
 * - data/favorites.md：存储收藏内容的 Markdown 文件，格式由 parseFavorites 定义
 */

import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import FavoriteCard from "@/components/FavoriteCard.astro";
import { parseFavorites } from "@/utils/parseFavorites";
import { SITE } from "@/config";
import { _t } from "@/i18n/lang";
import fs from "node:fs";
import path from "node:path";

/**
 * 构建收藏数据文件的绝对路径
 *
 * 处理步骤：
 * 1. 获取项目根目录路径（process.cwd()）
 * 2. 拼接 data/favorites.md 相对路径，得到完整的文件系统路径
 *
 * @example
 * // Windows: D:\haibao\GitHub\blog\data\favorites.md
 * // Linux: /home/user/blog/data/favorites.md
 */
const filePath = path.join(process.cwd(), "data/favorites.md");

/**
 * 读取并解析收藏数据
 *
 * 处理流程：
 * 1. 使用 fs.readFileSync 同步读取文件内容（构建时执行，不阻塞运行时）
 * 2. 使用 utf-8 编码解析文件内容为字符串
 * 3. 调用 parseFavorites 将 Markdown 内容转换为结构化的收藏项数组
 *
 * 返回值结构（由 parseFavorites 定义）：
 * - Array<FavoriteItem>，每个元素包含：
 *   - title: 收藏项标题
 *   - description: 收藏项描述
 *   - url: 收藏项链接
 *   - icon: 图标 URL（可选）
 *   - tags: 标签数组（可选）
 */
const content = fs.readFileSync(filePath, "utf-8");
const favorites = parseFavorites(content);
---

<Layout title={`${_t.favorites.title} | ${SITE.title}`}>
  <Header />
  <Main pageTitle="" pageDesc={_t.favorites.desc}>
    <ul class="favorites-list">
      {
        /**
         * 渲染收藏项列表
         *
         * 懒加载逻辑：
         * - 索引小于 SITE.favoritesPerIndex 的收藏项直接显示
         * - 索引大于等于该值的收藏项设置 hidden={true}，由懒加载脚本控制显示
         *
         * 参数传递：
         * - {...item}: 展开收藏项的所有属性到 FavoriteCard 组件
         * - itemClass: 设置 CSS 类名，供懒加载选择器使用
         * - hidden: 控制初始可见性
         */
        favorites.map((item, i) => (
          <FavoriteCard
            {...item}
            itemClass="favorites-item"
            hidden={i >= SITE.favoritesPerIndex}
          />
        ))
      }
    </ul>
    {/* 懒加载哨兵元素：用于 IntersectionObserver 检测滚动位置 */}
    <div id="favorites-sentinel" data-init={SITE.favoritesPerIndex} data-chunk={SITE.favoritesPerPage}></div>
  </Main>
  <Footer noMarginTop={true} />
</Layout>

<script is:inline src="/lazy-list.js"></script>
<script is:inline>
  /**
   * 初始化收藏页懒加载
   *
   * 配置说明：
   * - sentinelId: 哨兵元素的 ID，用于检测滚动位置
   * - itemSelector: 需要懒加载的收藏项卡片选择器
   *
   * 与归档页的差异：
   * - 未配置 artalk，表示不加载评论相关功能
   *
   * 事件监听：
   * - astro:after-swap: Astro 视图导航后触发（SPA 模式）
   * - astro:page-load: Astro 页面加载完成后触发
   */
  function boot(){
    window.setupLazyList({
      sentinelId: 'favorites-sentinel',
      itemSelector: '.favorites-item'
    });
  }

  // 确保在 Astro 页面切换和加载时都能正确初始化懒加载
  document.addEventListener('astro:after-swap', () => { if (typeof window.setupLazyList === 'function') boot(); });
  document.addEventListener('astro:page-load', () => { if (typeof window.setupLazyList === 'function') boot(); });
</script>
