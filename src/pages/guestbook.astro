---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import Artalk from "@/components/Artalk.astro";
import config from "@/config";
import { useTranslations } from "@/i18n";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.nav.guestbook} | ${config.site.title}`}>
  <Header pageTitle={t.nav.guestbook} />
  <Main class="app-prose">
    <Artalk pageKey="/guestbook/" pageTitle={t.nav.guestbook} class="mt-8" />
  </Main>
  <Footer />
</Layout>