---
/**
 * 留言板页
 *
 * @fileoverview 显示留言评论区域
 *
 * 核心逻辑：
 * 1. 使用 Artalk 组件提供评论功能
 * 2. 页面只包含评论容器，无其他内容
 * 3. 评论的 pageKey 自动设为当前路径
 *
 * 依赖关系：
 * - 被 /guestbook 路径访问
 * - 使用 Artalk 组件
 */

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import Artalk from "@/components/Artalk.astro";
import { SITE } from "@/config";
import { _t } from "@/i18n/lang";
---

<Layout title={`${_t.guestbook.title} | ${SITE.title}`}>
  <Header />
  <Main pageTitle="" pageDesc={_t.guestbook.desc}>
    <section class="mx-auto w-full max-w-3xl">
      <div id="Comments"></div>
    </section>
  </Main>
  <Footer />
</Layout>
<Artalk />

