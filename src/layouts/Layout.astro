---
/**
 * 基础布局组件
 *
 * @fileoverview 整个网站的最外层布局，包含 HTML head、meta 标签、全局样式
 *
 * 核心逻辑：
 * 1. SEO 优化：完整的 meta 标签、Open Graph、Twitter Cards
 * 2. Google 验证：支持 Google Search Console 验证
 * 3. View Transitions：启用 Astro 的页面切换动画
 * 4. 第三方集成：
 *    - Artalk 评论系统
 *    - Matomo 网站分析（仅生产环境）
 *    - Google Fonts 字体
 * 5. 条件加载：根据 toc、math 属性动态加载对应资源
 *
 * 依赖关系：
 * - 被 Main.astro、PostDetails.astro 等所有布局继承
 * - 导入全局样式、BackToTop 组件
 * - 使用 config.ts 获取站点配置
 */

import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";
import BackToTop from "@/components/BackToTop.astro";
import BackButton from "@/components/BackButton.astro";

// Google 站点验证码（环境变量）
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

/**
 * 组件属性接口
 *
 * @property title - 页面标题
 * @property author - 作者名称
 * @property profile - 作者主页链接
 * @property description - 页面描述
 * @property canonicalURL - 规范链接
 * @property pubDatetime - 发布时间
 * @property modDatetime - 更新时间
 * @property scrollSmooth - 是否启用平滑滚动
 * @property toc - 是否启用目录
 * @property math - 是否启用数学公式
 * @property comments - 是否启用评论
 */
export interface Props {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  toc?: boolean;
  math?: boolean;
  comments?: boolean;
}

// 解构属性，设置默认值
const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  // 移除 .html 扩展名，生成规范链接
  canonicalURL = new URL(Astro.url.pathname.replace(/\.html?$/, ""), Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  toc = false,
  math = false,
} = Astro.props;

const fullDescription = description;

/**
 * 结构化数据（JSON-LD）
 *
 * 用于搜索引擎理解页面内容，提升 SEO 效果
 * @see https://schema.org/BlogPosting
 */
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `${title}`,
  datePublished: `${pubDatetime?.toISOString()}`,
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: [
    {
      "@type": "Person",
      name: `${author}`,
      ...(profile && { url: profile }),
    },
  ],
};
---

<!doctype html>
<html lang=`${SITE.lang ?? "en"}` class={`${scrollSmooth && "scroll-smooth"}`}>
  <head>
    <!-- 基础 meta 标签 -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={fullDescription} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={SITE.langOg} />
    <meta property="og:type" content="website" />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={fullDescription} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    <!-- Google 站点验证（环境变量配置） -->
    {
      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }

    <!-- View transitions: https://docs.astro.build/en/guides/view-transitions/ -->
    <ClientRouter />

    <!-- 主题切换脚本 -->
    <script is:inline src="/toggle-theme.js"></script>

    <!-- Artalk 评论系统资源 -->
    <link href="https://cos.lhasa.icu/dist/artalk/Artalk.css" rel="stylesheet" />
    <script is:inline src="https://cos.lhasa.icu/dist/artalk/Artalk.js"></script>

    <!-- Matomo 网站分析（仅生产环境） -->
    {
      import.meta.env.PROD && (
        <script is:inline>
          var _paq = window._paq = window._paq || [];
          /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
          _paq.push(['trackPageView']);
          _paq.push(['enableLinkTracking']);
          (function() {
            var u="//analytics.lhasa.icu/";
            _paq.push(['setTrackerUrl', u+'matomo.php']);
            _paq.push(['setSiteId', '1']);
            var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
            g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
          })();
        </script>
      )
    }

    <!-- Clarity 网站分析（仅生产环境） -->
    {
      import.meta.env.PROD && (
        <script is:inline>
          (function(c,l,a,r,i,t,y){
              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
              t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "uwhxcctjc3");
        </script>
      )
    }

    <!-- Blogs Club 徽章预加载 -->
    <link rel="prefetch" as="image" href="https://www.blogsclub.org/badge/blog.lhasa.icu">

    <!-- TOC 样式（条件加载） -->
    {
      toc && (
        <link
          rel="stylesheet"
          href="/tocbot/tocbot.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
        />
      )
    }

    <!-- KaTeX 数学公式样式（条件加载） -->
    {
      math && (
        <link
          rel="stylesheet"
          href="https://cos.lhasa.icu/dist/css/katex.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
        />
      )
    }
  </head>
  <body class="site-outer-bg">
    <!-- 站点框架容器 -->
    <div
      id="site-frame"
      class="mx-auto w-full px-4 pt-3 sm:mt-5 sm:w-[768px] sm:max-w-[72rem] sm:bg-[var(--color-background)] sm:shadow-[0_8px_24px_rgba(0,0,0,0.15)] sm:px-[3.75rem] sm:pt-[1.875rem]"
    >
      <!-- 插槽：子布局内容 -->
      <slot />
    </div>
    <!-- 返回按钮 -->
    <BackButton />
    <!-- 返回顶部按钮 -->
    <BackToTop />
  </body>
</html>

<script is:inline>
window.__artalkConfig = { server: 'https://artalk.lhasa.icu', site: '游钓四方的博客' };
document.addEventListener('astro:after-swap', tryLoad);
document.addEventListener('DOMContentLoaded', tryLoad);
/**
 * 加载 Artalk 评论数统计组件
 *
 * 功能：
 * 1. 查找所有 .artalk-comment-count 元素
 * 2. 调用 Artalk.loadCountWidget 加载评论数
 * 3. 使用 data-page-key 属性标识每篇文章
 */
function tryLoad() {
  const els = document.querySelectorAll('.artalk-comment-count');
  if (!els.length || typeof window === 'undefined' || typeof window.Artalk === 'undefined') return;
  const cfg = window.__artalkConfig || {};
  if (!cfg.server || !cfg.site) return;
  window.Artalk.loadCountWidget({
    server: cfg.server,
    site: cfg.site,
    countEl: '.artalk-comment-count',
    statPageKeyAttr: 'data-page-key',
  });
}
</script>

<style>
  /* 全局样式重置 */
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  .site-outer-bg {
    background-color: var(--page-background);
  }

  /* Frame inline padding as CSS variable for image bleed calculations */
  #site-frame {
    --frame-pad-inline: 1rem;
  }
  @media (min-width: 640px) {
    #site-frame {
      --frame-pad-inline: 3.75rem;
    }
  }

  /* 移动端背景色处理 */
  @media (max-width: 639px) {
    .site-outer-bg {
      background-color: var(--color-background);
    }
  }
</style>
