---
import { SITE } from "@/config";

export interface Props {
  src: string;
  alt: string;
  class?: string;
  style?: string;
  tags?: false | 'l' | 's';
  exif?: boolean;
}

const { 
  src, 
  alt, 
  class: className, 
  style, 
  tags = SITE.imageConfig.tags.defaultStyle, 
  exif = SITE.imageConfig.exif.enabled 
} = Astro.props;

/**
 * 去除最后一个扩展名（保留名称中的其他点）
 */
const stripExtension = (name: string): string => {
  return name.replace(/\.[^\/.]+$/, '');
};

const getPageSlug = (): string | undefined => {
  try {
    const pathname = Astro.url.pathname;
    const pathSegments = pathname.split('/').filter(Boolean);
    if (pathSegments.length > 0) {
      const lastSegment = pathSegments[pathSegments.length - 1];
      return stripExtension(lastSegment);
    }
    if (typeof window === 'undefined' && Astro.request) {
      const url = new URL(Astro.request.url);
      const segments = url.pathname.split('/').filter(Boolean);
      if (segments.length > 0) {
        return stripExtension(segments[segments.length - 1]);
      }
    }
    return undefined;
  } catch {
    return undefined;
  }
};

/**
 * 构建图片的完整 CDN 路径（支持绝对 URL 直通）
 */
const buildImagePath = (imageSrc: string): string => {
  // 如果已经是完整URL，直接返回
  if (imageSrc.startsWith('http://') || imageSrc.startsWith('https://')) {
    return imageSrc;
  }
  
  // 如果包含CDN域名，说明已经是完整路径
  if (imageSrc.includes('cos.lhasa.icu')) {
    return imageSrc;
  }
  
  const finalSlug = getPageSlug();
  
  if (finalSlug) {
    return `${SITE.imageConfig.imagesUrl}/${finalSlug}/${imageSrc}`;
  }
  
  return `${SITE.imageConfig.imagesUrl}/${imageSrc}`;
};

const finalSrc = buildImagePath(src);

/**
 * 将图片 URL 映射为 EXIF API URL
 */
const generateExifUrl = (imageSrc: string): string => {
  return imageSrc.replace(SITE.imageConfig.imagesUrl, SITE.imageConfig.exifUrl);
};

const exifUrl = exif ? generateExifUrl(finalSrc) : undefined;

const galleryName = getPageSlug() ?? 'images';
---

<!-- 图片容器：使用 figure 包装，响应式居中 -->
<figure class={`my-6 text-center -mx-4 w-[calc(100%+2rem)] max-w-[calc(100%+2rem)] sm:-mx-[3.75rem] sm:w-[calc(100%+7.5rem)] sm:max-w-[calc(100%+7.5rem)] ${className || ''}`} style={style}>
  <div class="relative block w-full overflow-hidden lightbox">
    <!-- EXIF 提示框（启用时注入并在 hover 显示） -->
    {exif && (
      <div class="absolute top-0 left-0 right-0 h-[25px] opacity-0 transition-opacity duration-500 ease-out z-50 pointer-events-none bg-gradient-to-b from-black/60 to-transparent exif-tooltip" data-exif-tooltip>
        <div class="px-[15px] py-0 h-[25px] leading-[25px] text-sm text-white bg-transparent text-center exif-content whitespace-nowrap overflow-hidden text-ellipsis max-w-full">
          <div class="opacity-70 italic exif-loading">Loading EXIF data...</div>
        </div>
      </div>
    )}
    
    <!-- 图片链接：用于灯箱展示与描述 -->
    <a 
      href={finalSrc}
      class="glightbox"
      data-gallery={galleryName}
      {...(alt && alt.trim() ? {
        'data-description': alt,
        'data-desc-position': 'bottom',
        'data-desc-merged': '0'
      } : {})}
      data-type="image"
       >
      <!-- 主图：携带 EXIF 元数据属性 -->
      <img 
      src={finalSrc} 
      alt={alt}
      title={alt}
      loading={SITE.imageConfig.loading.lazy ? "lazy" : "eager"}
      class="w-full h-auto shadow-lg transition-all duration-300 ease-in-out block object-cover cursor-pointer not-prose img-main"
      data-exif-url={exifUrl ? exifUrl + "?exif" : undefined}
      data-show-exif={exif} />
    </a>
    
    <!-- 图片标签：根据 tags 属性渲染长条或角标样式 -->
    {tags && alt && alt.trim() && (
    <figcaption class={`absolute m-0 p-0 max-w-full img-tags ${tags === 'l' ? 'tags-bar bottom-0 left-0 right-0' : 'tags-tag bottom-2 left-2 max-w-[calc(100%-1rem)]'}`}>
      <span class={`text-white font-medium shadow-text-lg whitespace-nowrap overflow-hidden text-ellipsis max-w-full tags-text ${tags === 'l' ? 'block h-[30px] leading-[30px] px-[10px] py-0 text-[12px] bg-gradient-to-r from-black/80 to-transparent text-left' : 'inline-block px-3 py-2 text-sm font-semibold leading-tight'}`}>{alt}</span>
      </figcaption>
    )}
  </div>
</figure>
<script>
  import '@/utils/images';
  import { initLightbox } from '@/utils/lightbox';
  initLightbox();
</script>

<style>
  @reference "tailwindcss";
  
  /* EXIF 提示框显示态 */
  .exif-tooltip.show {
    @apply opacity-70 pointer-events-auto;
  }

  /* EXIF 文本行布局 */
  :global(.exif-content .exif-row) {
    @apply inline-flex items-center gap-3 md:gap-6;
  }

  /* EXIF 单项样式 */
  :global(.exif-content .exif-item) {
    @apply leading-tight;
  }

  /* EXIF 文本样式继承 */
  .exif-text,
  .exif-loading {
    color: inherit;
    font: inherit;
    text-shadow: inherit;
  }

  /* 文本阴影工具类 */
  .shadow-text-lg {
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
  }
  
  /* 移动端响应式优化 */
  @media (max-width: 768px) {
    .img-tags .tags-text {
      @apply text-xs;
    }
    
    .tags-tag .tags-text {
      @apply text-xs px-2.5 py-0.5;
    }
    
    .tags-tag {
      @apply bottom-1.5 left-1.5;
    }
  }
  
  /* 超小屏优化 */
  @media (max-width: 480px) {
    .img-tags .tags-text {
      @apply text-[0.6rem];
    }
    
    .tags-tag .tags-text {
      @apply text-[0.6rem] px-2 py-1;
    }
    
    .tags-tag {
      @apply bottom-1 left-1;
    }
  }
</style>
