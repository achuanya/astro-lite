---
---
<div id="year-progress" class="group relative mx-auto w-full max-w-3xl mb-5 sm:mb-0">
  <div class="h-[3px] w-full rounded bg-border/70" aria-hidden="true">
    <div id="year-progress-fill" class="h-[3px] w-0 rounded" style="background-color: var(--year-progress-fill)"></div>
  </div>
  <span
    id="year-progress-cover"
    class="absolute left-0 top-1/2 -translate-y-1/2 h-[3px] rounded bg-background pointer-events-none opacity-0 transition-opacity duration-[1000ms] ease-out z-10"
  ></span>
  <span
    id="year-progress-label"
    class="absolute left-0 top-1/2 -translate-y-1/2 whitespace-nowrap text-xs text-accent/70 opacity-0 transition-opacity duration-[1000ms] ease-out pointer-events-none z-20 px-2"
  ></span>
  <div
    id="year-progress-popup"
    class="absolute left-0 top-0 -translate-y-[calc(100%+8px)] whitespace-nowrap text-xs bg-background text-foreground border border-border rounded px-2 py-1 shadow opacity-0 transition-opacity duration-[1000ms] ease-out pointer-events-none z-30"
  ></div>
</div>

<script is:inline>
  function renderYearProgress() {
    const now = new Date();
    const start = new Date(now.getFullYear(), 0, 1);
    const end = new Date(now.getFullYear() + 1, 0, 1);
    const target = Math.min(1, Math.max(0, (now.getTime() - start.getTime()) / (end.getTime() - start.getTime())));
    const fill = document.getElementById('year-progress-fill');
    const label = document.getElementById('year-progress-label');
    const cover = document.getElementById('year-progress-cover');
    const container = document.getElementById('year-progress');
    const popup = document.getElementById('year-progress-popup');
    if (!fill || !label || !container || !cover || !popup) return;

    function show(el) {
      if (!el) return;
      el.classList.add('duration-300');
      el.classList.add('opacity-100');
    }

    function hide(el) {
      if (!el) return;
      el.classList.remove('duration-300');
      el.classList.remove('opacity-100');
    }

    const finalText = (target * 100).toFixed(1) + '%';
    container.setAttribute('title', finalText);
    show(label);
    show(cover);
    const duration = 1200;
    const startTs = performance.now();
    let currentProgress = 0;
    let hoverHideTimer = null;
    function positionLabel(progress) {
      const cw = container.getBoundingClientRect().width;
      const lw = label.getBoundingClientRect().width || 0;
      const xLabel = Math.min(Math.max(cw * progress - lw / 2, 0), cw - lw);
      label.style.left = xLabel + 'px';
      const cover = document.getElementById('year-progress-cover');
      if (cover) {
        cover.style.left = xLabel + 'px';
        cover.style.width = Math.max(lw, 0) + 'px';
      }
      const pw = popup.getBoundingClientRect().width || 0;
      const xPopup = Math.min(Math.max(cw * progress - pw / 2, 0), cw - pw);
      popup.style.left = xPopup + 'px';
    }
    function step(ts) {
      const t = Math.min(1, (ts - startTs) / duration);
      const current = target * t;
      currentProgress = current;
      fill.style.width = (current * 100).toFixed(3) + '%';
      label.textContent = (current * 100).toFixed(1) + '%';
      positionLabel(current);
      if (t < 1) {
        requestAnimationFrame(step);
      } else {
        label.textContent = finalText;
        positionLabel(target);
        currentProgress = target;
        setTimeout(() => {
          hide(label);
          hide(cover);
        }, 2000);
      }
    }
    requestAnimationFrame(step);
    if (!container.dataset.bound) {
      container.addEventListener('mouseenter', () => {
        if (hoverHideTimer) {
          clearTimeout(hoverHideTimer);
          hoverHideTimer = null;
        }
        show(label);
        show(cover);
        positionLabel(currentProgress || target);
      });
      container.addEventListener('mouseleave', () => {
        if (hoverHideTimer) clearTimeout(hoverHideTimer);
        hoverHideTimer = setTimeout(() => {
          hide(label);
          hide(cover);
        }, 1000);
      });
      container.addEventListener('click', () => {
        const now = new Date();
        const end = new Date(now.getFullYear() + 1, 0, 1);
        const daysLeft = Math.ceil((end.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
        popup.textContent = `今年还剩下${daysLeft}天，要珍惜时间啊！`;
        show(popup);
        positionLabel(currentProgress || target);
        if (window.__ypHideTimer) clearTimeout(window.__ypHideTimer);
        window.__ypHideTimer = setTimeout(() => {
          hide(popup);
        }, 2000);
      });
      container.dataset.bound = '1';
    }
  }

  renderYearProgress();
  document.addEventListener('astro:after-swap', renderYearProgress);
  window.addEventListener('resize', renderYearProgress);
</script>